# API keys — never commit
.env

# Virtual environment — too large, recreated via requirements.txt
venv/

# Vector database — too large (>25MB), recreated by running ingest_documents.py
chroma_db/

# SQLite databases — generated at runtime
database/*.db

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs — generated at runtime
system.log
*.log

# OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/
